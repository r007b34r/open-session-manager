{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Session Governance",
  "version": "0.1.0",
  "identifier": "local.max.agent-session-governance",
  "build": {
    "beforeDevCommand": "npm --prefix ../web run dev -- --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "npm --prefix ../web run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Session Governance",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
