  },
  "settings": {
    "env": {
      "OPENAI_API_KEY": "sk-qwen-project-1234567890"
    }
  },
  "mcpServers": {
    "filesystem": {
      "command": "node",
      "args": ["mcp-project-filesystem.js"]
    }
  }
}
